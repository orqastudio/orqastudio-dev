{
  "name": "OrqaStudio Dev",
  "organisation": true,
  "dogfood": true,
  "projects": [
    {
      "name": "app",
      "path": "app"
    },
    {
      "name": "types",
      "path": "libs/types"
    },
    {
      "name": "sdk",
      "path": "libs/sdk"
    },
    {
      "name": "cli",
      "path": "libs/cli"
    },
    {
      "name": "connector-claude-code",
      "path": "connectors/claude-code"
    },
    {
      "name": "components",
      "path": "libs/svelte-components"
    },
    {
      "name": "visualiser",
      "path": "libs/graph-visualiser"
    }
  ],
  "description": "Organisation-mode development environment for the OrqaStudio ecosystem",
  "default_model": "auto",
  "excluded_paths": [
    "node_modules",
    ".git",
    "target",
    "dist",
    "build"
  ],
  "stack": null,
  "governance": null,
  "icon": null,
  "show_thinking": false,
  "custom_system_prompt": null,
  "artifacts": [
    {
      "key": "principles",
      "label": "Principles",
      "icon": "landmark",
