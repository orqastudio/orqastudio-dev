          "path": ".orqa/process/decisions"
        },
        {
          "key": "rule",
          "label": "Rules",
          "icon": "shield",
          "path": ".orqa/process/rules"
        },
        {
          "key": "lesson",
          "label": "Lessons",
          "icon": "book-open",
          "path": ".orqa/process/lessons"
        },
        {
          "key": "knowledge",
          "label": "Knowledge",
          "icon": "book-open",
          "path": ".orqa/process/knowledge"
