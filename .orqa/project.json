  "artifactLinks": {
    "displayModes": {
      "TASK": "title",
      "DOC": "title",
      "AD": "title",
      "RULE": "title",
      "PILLAR": "title",
      "KNOW": "title",
      "MS": "title",
      "EPIC": "title",
      "IMPL": "title",
      "RES": "title",
      "IDEA": "title",
      "AGENT": "title"
    },
    "colors": {
      "AD": "#8b5cf6",
      "TASK": "#06b6d4",
      "RULE": "#a78bfa",
      "IDEA": "#c084fc",
      "PILLAR": "#818cf8",
      "DOC": "#94a3b8",
      "KNOW": "#2dd4bf",
      "RES": "#6366f1",
      "AGENT": "#f472b6",
      "EPIC": "#3b82f6",
      "IMPL": "#67e8f9",
      "MS": "#38bdf8"
    }
  },
  "statuses": [
    {
      "key": "captured",
      "label": "Captured",
      "icon": "circle-dot",
      "spin": false,
      "transitions": [
        "exploring",
        "ready",
        "archived"
      ],
      "auto_rules": []
    },
    {
      "key": "exploring",
      "label": "Exploring",
      "icon": "search",
      "spin": false,
      "transitions": [
        "ready",
        "captured",
        "archived"
      ],
      "auto_rules": []
    },
    {
      "key": "ready",
      "label": "Ready",
      "icon": "check-circle",
      "spin": false,
      "transitions": [
        "prioritised",
        "exploring",
        "archived"
      ],
      "auto_rules": []
    },
    {
      "key": "prioritised",
      "label": "Prioritised",
      "icon": "arrow-up-circle",
      "spin": false,
      "transitions": [
        "active",
        "ready",
        "archived"
      ],
      "auto_rules": []
    },
    {
      "key": "active",
      "label": "Active",
      "icon": "loader",
      "spin": true,
      "transitions": [
        "review",
        "hold",
        "blocked"
      ],
      "auto_rules": []
    },
    {
      "key": "hold",
      "label": "Hold",
      "icon": "pause-circle",
      "spin": false,
      "transitions": [
        "active",
        "archived"
      ],
      "auto_rules": []
    },
    {
      "key": "blocked",
      "label": "Blocked",
      "icon": "x-circle",
      "spin": false,
      "transitions": [
        "active",
        "archived"
      ],
      "auto_rules": [
        {
          "condition": "all-dependencies-completed",
          "target": "active"
        }
      ]
    },
    {
      "key": "review",
      "label": "Review",
      "icon": "eye",
      "spin": false,
      "transitions": [
        "completed",
        "active"
      ],
      "auto_rules": []
    },
    {
      "key": "completed",
      "label": "Completed",
      "icon": "check-circle-2",
      "spin": false,
      "transitions": [
        "archived"
      ],
      "auto_rules": []
    },
    {
      "key": "surpassed",
      "label": "Surpassed",
      "icon": "fast-forward",
      "spin": false,
      "transitions": [
        "archived"
      ],
      "auto_rules": []
    },
    {
      "key": "archived",
      "label": "Archived",
      "icon": "archive",
      "spin": false,
      "transitions": [],
      "auto_rules": []
    },
    {
      "key": "recurring",
      "label": "Recurring",
      "icon": "repeat",
      "spin": false,
      "transitions": [
        "archived"
      ],
      "auto_rules": []
    }
  ],
  "delivery": {
    "types": [
      {
        "key": "milestone",
        "label": "Milestone",
        "path": ".orqa/delivery/milestones",
        "parent": null,
        "gate_field": "gate"
      },
      {
        "key": "epic",
        "label": "Epic",
        "path": ".orqa/delivery/epics",
        "parent": {
          "type": "milestone",
          "relationship": "delivers"
        },
        "gate_field": null
      },
      {
        "key": "task",
        "label": "Task",
        "path": ".orqa/delivery/tasks",
        "parent": {
          "type": "epic",
          "relationship": "delivers"
        },
        "gate_field": null
      }
    ]
  },
  "relationships": [
    {
      "key": "depends-on",
      "inverse": "depended-on-by",
      "label": "Depends On",
      "inverse_label": "Depended On By"
    }
  ],
  "plugins": {
    "@orqastudio/plugin-claude": {
      "installed": true,
      "enabled": true,
      "path": "plugins/claude",
      "relationships": null,
      "config": null
    },
    "@orqastudio/plugin-svelte": {
      "installed": true,
      "enabled": true,
      "path": "plugins/svelte",
      "relationships": null,
      "config": null
    },
    "@orqastudio/plugin-rust": {
      "installed": true,
      "enabled": true,
      "path": "plugins/rust",
      "relationships": null,
