    {
      "key": "documentation",
      "label": "Documentation",
      "icon": "file-text",
      "children": [
        {
          "key": "doc",
          "label": "Project Docs",
          "icon": "file-text",
          "path": ".orqa/documentation/project"
        }
      ]
    }
